# .env.example — copy to .env and fill in real values. NEVER commit the real .env.
# Next.js exposes only NEXT_PUBLIC_* vars to the browser; everything else is server-only.

# Supabase (public — safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_your-key

# Supabase secret key — SERVER ONLY. Full admin, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_your-key

# URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEBSITE_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3001

# CORS allowlist for API route handlers
ALLOWED_ORIGINS=http://localhost:3001,https://jacal.io,https://www.jacal.io

# SMTP / transactional email (server only) — slated to move to Resend
HOSTINGER_EMAIL_USER=support@jacal.io
HOSTINGER_EMAIL_PASSWORD=your-smtp-password
INTERNAL_EMAIL_SECRET=generate-a-long-random-string

# Email metadata (frontend)
NEXT_PUBLIC_FROM_EMAIL=support@jacal.io
NEXT_PUBLIC_FROM_NAME=Jacal Learning Platform
NEXT_PUBLIC_SUPPORT_EMAIL=support@jacal.io

# Clerk (added during the Clerk migration phase)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
