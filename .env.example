# .env.example — copy to .env and fill in real values. NEVER commit the real .env.

# Supabase (public — safe to expose to the browser)
REACT_APP_SUPABASE_URL=https://your-project.supabase.co
REACT_APP_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — SERVER ONLY. Full admin, bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# URLs
REACT_APP_API_URL=http://localhost:3002
FRONTEND_URL=http://localhost:3001
REACT_APP_WEBSITE_URL=http://localhost:3001
WEBSITE_URL=http://localhost:3001

# Comma-separated list of origins allowed to call the API (CORS allowlist)
ALLOWED_ORIGINS=http://localhost:3001,https://jacal.io,https://www.jacal.io

# Server
PORT=3001
NODE_ENV=development

# SMTP (server only)
HOSTINGER_EMAIL_USER=support@jacal.io
HOSTINGER_EMAIL_PASSWORD=your-smtp-password

# Shared secret required to call the internal /api/send-email relay (server only)
INTERNAL_EMAIL_SECRET=generate-a-long-random-string

# Email metadata (frontend)
REACT_APP_FROM_EMAIL=support@jacal.io
REACT_APP_FROM_NAME=Jacal Learning Platform
REACT_APP_SUPPORT_EMAIL=support@jacal.io

# Email metadata (backend)
FROM_EMAIL=support@jacal.io
FROM_NAME=Jacal Learning Platform
SUPPORT_EMAIL=support@jacal.io
